{
  "name": "meetings-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "setup": "powershell -ExecutionPolicy Bypass -File ./scripts/setup-env.ps1",
    "start": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-setup.ps1",
    "start:linux": "chmod +x ./scripts/dev-setup.sh && ./scripts/dev-setup.sh",
    "start:prod": "podman-compose up -d && npm run dev",
    "stop": "podman compose down",
    "dev": "concurrently \"npm run dev:fe\" \"npm run dev:be\" \"npm run docs:dev\"",
    "dev:fe": "vite --host",
    "dev:be": "node mock_agent/server.cjs",
    "build": "vite build",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "docs:dev": "vitepress dev docs --host",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "couchbase": "^4.4.3",
    "express": "^5.2.1",
    "keycloak-js": "^26.2.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "mermaid": "^11.15.0",
    "sass": "^1.77.6",
    "vite": "^5.3.1",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17"
  }
}
