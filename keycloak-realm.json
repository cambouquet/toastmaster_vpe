{
  "realm": "toastmaster",
  "enabled": true,
  "clients": [
    {
      "clientId": "mission-control",
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "webOrigins": ["*"],
      "redirectUris": ["http://localhost:1777/*", "https://k-app.tech/*"]
    }
  ],
  "roles": {
    "realm": [
      { "name": "VPE" },
      { "name": "MEMBER" },
      { "name": "GUEST" }
    ]
  },
  "users": [
    {
      "username": "vpe",
      "enabled": true,
      "realmRoles": ["VPE"],
      "credentials": [{ "type": "password", "value": "vpe", "temporary": false }]
    },
    {
      "username": "member",
      "enabled": true,
      "realmRoles": ["MEMBER"],
      "credentials": [{ "type": "password", "value": "member", "temporary": false }]
    }
  ]
}
